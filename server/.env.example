# ===== Replicate (필수) =====
# replicate.com → Account → API tokens 에서 발급
REPLICATE_API_TOKEN=

# --- 배경 제거(컷아웃): 데모에서 라이브 호출, 빠르고 저렴 ---
# 공식/커뮤니티 모델은 "owner/name"(최신 버전 자동), 버전 고정은 "owner/name:<hash>"
REPLICATE_CUTOUT_MODEL=851-labs/background-remover
# 이 모델의 입력 이미지 필드명 (대부분 image)
REPLICATE_CUTOUT_IMAGE_KEY=image
# (선택) 추가 입력 파라미터 JSON 한 줄
# REPLICATE_CUTOUT_INPUT_JSON={"format":"png"}

# --- 이미지 → 비디오(애니메이트): 느리고 유료 → 데모에서는 사전 생성 권장 ---
REPLICATE_ANIMATE_MODEL=stability-ai/stable-video-diffusion
# 이 모델의 입력 이미지 필드명 (SVD=input_image)
REPLICATE_ANIMATE_IMAGE_KEY=input_image
# (선택) SVD 권장값 예시
# REPLICATE_ANIMATE_INPUT_JSON={"video_length":"14_frames_with_svd","sizing_strategy":"maintain_aspect_ratio","frames_per_second":6,"motion_bucket_id":127,"cond_aug":0.02}

# ===== 서버 =====
PORT=8787
# 프론트 도메인(콤마 구분). 개발 중엔 * 허용.
ALLOWED_ORIGINS=*
