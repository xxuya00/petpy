# ===== Replicate (이미지 → 비디오) =====
REPLICATE_API_TOKEN=
# 모델 식별자. 공식 모델은 "owner/name" (최신 버전 자동),
# 특정 버전 고정은 "owner/name:<version-hash>".
REPLICATE_MODEL=stability-ai/stable-video-diffusion
# 모델의 입력 이미지 필드명 (SVD=input_image, 다른 모델은 image 등)
REPLICATE_IMAGE_KEY=input_image
# (선택) 추가 입력 파라미터 JSON 한 줄. SVD 권장값 예시:
# REPLICATE_INPUT_JSON={"video_length":"14_frames_with_svd","sizing_strategy":"maintain_aspect_ratio","frames_per_second":6,"motion_bucket_id":127,"cond_aug":0.02}

# ===== AWS (Rekognition + S3 + DynamoDB) =====
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
DDB_TABLE=petpy-posts

# ===== 서버 =====
PORT=8787
# 프론트(Netlify) 도메인. 여러 개면 콤마로 구분. 개발 중엔 * 허용.
ALLOWED_ORIGINS=*
# 동물 판정 신뢰도(%) 임계값
MODERATION_MIN_CONFIDENCE=80
# presigned URL 만료(초, 최대 604800=7일)
PRESIGN_EXPIRES=604800
